# Frontend (Supabase → Settings → API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Ixtiyoriy — og:url va og:image uchun to‘liq domen (masalan https://sizning-domen.uz)
# VITE_SITE_URL=https://sizning-domen.uz

# Vercel: shu ikkalasini ham Project → Settings → Environment Variables da
# Production (va kerak bo‘lsa Preview) uchun qo‘shing — Vite ularni BUILD vaqtida o‘qiydi.
# Qo‘shgach yangi deploy qiling (Redeploy).

# Ixtiyoriy — faqat npm run bootstrap:admin uchun (Lovable da odatda kerak emas)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
